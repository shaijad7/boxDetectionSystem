# -------------------------------------------
# Firebase Admin SDK Credentials
# -------------------------------------------
# Path to your downloaded Firebase service account JSON key
FIREBASE_CREDENTIALS_PATH=../shared/config/firebase_config.json

# Firebase project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# -------------------------------------------
# Model Configuration
# -------------------------------------------
# Path to YOLO weights file (relative to backend/)
MODEL_WEIGHTS_PATH=weights/box_detection_model.pt

# Confidence threshold for detections (0.0 - 1.0)
DETECTION_CONFIDENCE=0.5

# -------------------------------------------
# API Configuration
# -------------------------------------------
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server host and port
HOST=0.0.0.0
PORT=8000
